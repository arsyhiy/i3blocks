# --- Keyboard layout ---
[layout]
command=~/.config/i3blocks/layout.sh
interval=1

# --- Wi-Fi ---
[wifi]
command=~/.config/i3blocks/wifi.sh
interval=5

# --- Battery ---
[battery]
command=~/.config/i3blocks/battery.sh
interval=10

# --- Volume ---
[volume]
command=~/.config/i3blocks/volume.sh
interval=once
signal=10

# --- Time ---
[time]
command=date '+%Y-%m-%d %H:%M:%S'
interval=1
